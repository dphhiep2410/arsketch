<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/constraintLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".ui.trace.TraceActivity">



        <RelativeLayout
            android:id="@+id/backgroundMain"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@id/containerController">

            <com.example.arsketch.common.custom.RotateZoomImageView
                android:id="@+id/photoView"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:scaleType="centerCrop" />
        </RelativeLayout>

        <FrameLayout
            android:id="@+id/bannerAds"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent" />
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/containerController"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#80000000"
            android:paddingVertical="@dimen/_12sdp"
            app:layout_constraintTop_toBottomOf="@id/bannerAds">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="@dimen/_32sdp"
                android:layout_height="@dimen/_32sdp"
                android:foreground="@drawable/fg_ripple_effect"
                android:padding="@dimen/_4sdp"
                android:src="@drawable/ic_back"
                app:layout_constraintEnd_toStartOf="@id/btnColorPicker"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/btnColorPicker"
                android:layout_width="@dimen/_32sdp"
                android:layout_height="@dimen/_32sdp"
                android:foreground="@drawable/fg_ripple_effect"
                android:padding="@dimen/_4sdp"
                android:src="@drawable/ic_color_picker"
                app:layout_constraintEnd_toStartOf="@id/btnToggleDirection"
                app:layout_constraintStart_toEndOf="@id/btnBack"
                app:layout_constraintTop_toTopOf="parent" />


            <ImageView
                android:id="@+id/btnToggleDirection"
                android:layout_width="@dimen/_32sdp"
                android:layout_height="@dimen/_32sdp"
                android:foreground="@drawable/fg_ripple_effect"
                android:padding="@dimen/_4sdp"
                android:src="@drawable/ic_toggle_direction"
                app:layout_constraintEnd_toStartOf="@id/btnLock"
                app:layout_constraintStart_toEndOf="@id/btnColorPicker"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/btnLock"
                android:layout_width="@dimen/_32sdp"
                android:layout_height="@dimen/_32sdp"
                android:foreground="@drawable/fg_ripple_effect"
                android:padding="@dimen/_4sdp"
                android:src="@drawable/ic_unlock"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/btnToggleDirection"
                app:layout_constraintTop_toTopOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>


    </androidx.constraintlayout.widget.ConstraintLayout>

    <include
        android:id="@+id/bottomSheet"
        layout="@layout/dialog_bottom_sketch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:behavior_peekHeight="@dimen/_120sdp"
        app:layout_behavior="@string/bottom_sheet_behavior" />

    <com.dream.libads.admob.NativeCollapseAdmob
        android:id="@+id/nativeAd"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_primary_stroke_12"
        android:visibility="gone" />
</androidx.coordinatorlayout.widget.CoordinatorLayout>
