<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.splash.SplashActivity">

    <ImageView
        android:id="@+id/imvAppName"
        android:layout_width="match_parent"
        android:layout_height="@dimen/_50sdp"
        android:layout_marginHorizontal="@dimen/_30sdp"
        android:src="@drawable/ic_app_name"
        app:layout_constraintBottom_toTopOf="@id/ic_splash" />

    <ImageView
        android:id="@+id/ic_splash"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:src="@drawable/ic_splash"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent"
         />

    <com.dream.libads.admob.NativeAdStyle3
        android:id="@+id/nativeView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:background="@drawable/bg_primary_stroke_white"
        app:layout_constraintBottom_toTopOf="@id/lottie_loading" />
    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/lottie_loading"
        android:layout_width="match_parent"
        android:layout_height="@dimen/_60sdp"
        android:scaleX="1"
        android:scaleY="1"
        app:layout_constraintBottom_toTopOf="@id/tvLoadingAds"
        app:lottie_autoPlay="true"
        app:lottie_rawRes="@raw/anim_draw"
        app:lottie_repeatCount="-1"
        app:lottie_repeatMode="restart"
        app:lottie_speed="1" />

    <TextView
        android:id="@+id/tvLoadingAds"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/_12sdp"
        android:fontFamily="@font/f400"
        android:text="@string/this_action_can_contain_ads"
        android:textColor="@color/black"
        android:textSize="@dimen/_14sdp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <FrameLayout
        android:id="@+id/bannerAds"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent" />

    <FrameLayout
        android:id="@+id/mrecAds"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/imvAppName" />

</androidx.constraintlayout.widget.ConstraintLayout>