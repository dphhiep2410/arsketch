<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.draw.DrawActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/containerController"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingVertical="@dimen/_12sdp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="@dimen/_32sdp"
            android:layout_height="@dimen/_32sdp"
            android:foreground="@drawable/fg_ripple_effect"
            android:padding="@dimen/_4sdp"
            android:src="@drawable/ic_close"
            app:layout_constraintEnd_toStartOf="@id/btnUndo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/black" />

        <ImageView
            android:id="@+id/btnUndo"
            android:layout_width="@dimen/_32sdp"
            android:layout_height="@dimen/_32sdp"
            android:foreground="@drawable/fg_ripple_effect"
            android:padding="@dimen/_4sdp"
            android:src="@drawable/ic_undo"
            app:layout_constraintEnd_toStartOf="@id/btnForward"
            app:layout_constraintStart_toEndOf="@id/btnBack"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/btnForward"
            android:layout_width="@dimen/_32sdp"
            android:layout_height="@dimen/_32sdp"
            android:foreground="@drawable/fg_ripple_effect"
            android:padding="@dimen/_4sdp"
            android:src="@drawable/ic_foward"
            app:layout_constraintEnd_toStartOf="@id/btnSave"
            app:layout_constraintStart_toEndOf="@id/btnUndo"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/btnSave"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_primary_50"
            android:fontFamily="@font/f700"
            android:foreground="@drawable/fg_ripple_effect_50"
            android:paddingHorizontal="@dimen/_12sdp"
            android:paddingVertical="@dimen/_8sdp"
            android:text="@string/save"
            android:textColor="@color/white"
            android:textSize="@dimen/_14sdp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/btnForward"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.example.arsketch.common.custom.FingerPaintImageView
        android:id="@+id/paintView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:src="@color/n6"
        app:inEditMode="true"
        app:layout_constraintBottom_toTopOf="@+id/containerBottom"
        app:layout_constraintTop_toBottomOf="@id/containerController" />


    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/containerBottom"
        android:layout_width="match_parent"
        android:layout_height="@dimen/_90sdp"
        android:layout_marginBottom="@dimen/_12sdp"
        app:layout_constraintBottom_toTopOf="@id/nativeAdmob">

        <androidx.appcompat.widget.AppCompatSeekBar
            android:id="@+id/seekBarPenWidth"
            android:layout_width="match_parent"
            android:layout_height="@dimen/_20sdp"
            android:layout_marginStart="@dimen/_6sdp"
            android:layout_marginBottom="@dimen/_12sdp"
            android:max="30"
            android:progressDrawable="@drawable/custom_seekbar"
            android:splitTrack="false"
            android:thumb="@drawable/custom_thumb"
            app:layout_constraintBottom_toTopOf="@id/btnPen" />

        <androidx.appcompat.widget.AppCompatSeekBar
            android:id="@+id/seekbarEraserWidth"
            android:layout_width="match_parent"
            android:layout_height="@dimen/_20sdp"
            android:layout_marginStart="@dimen/_6sdp"
            android:layout_marginBottom="@dimen/_12sdp"
            android:max="30"
            android:progressDrawable="@drawable/custom_seekbar"
            android:splitTrack="false"
            android:thumb="@drawable/custom_thumb"
            app:layout_constraintBottom_toTopOf="@id/btnPen" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rcvPenColor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            app:layout_constraintBottom_toTopOf="@id/btnPen" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rcvBgColor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            app:layout_constraintBottom_toTopOf="@id/btnPen" />

        <TextView
            android:id="@+id/btnPen"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/f500"
            android:foreground="@drawable/fg_ripple_effect"
            android:text="@string/pen"
            android:textColor="@color/primary"
            android:textSize="@dimen/_14sdp"
            app:drawableTopCompat="@drawable/ic_pen"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnPenColor"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/btnPenColor"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/f500"
            android:foreground="@drawable/fg_ripple_effect"
            android:text="@string/pen_color"
            android:textColor="@color/n3"
            android:textSize="@dimen/_14sdp"
            app:drawableTopCompat="@drawable/ic_pen_color"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnEraser"
            app:layout_constraintStart_toEndOf="@id/btnPen" />

        <TextView
            android:id="@+id/btnEraser"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/f500"
            android:foreground="@drawable/fg_ripple_effect"
            android:text="@string/eraser"
            android:textColor="@color/n3"
            android:textSize="@dimen/_14sdp"
            app:drawableTopCompat="@drawable/ic_eraser"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnBGColor"
            app:layout_constraintStart_toEndOf="@id/btnPenColor" />

        <TextView
            android:id="@+id/btnBGColor"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/f500"
            android:foreground="@drawable/fg_ripple_effect"
            android:text="@string/bg_color"
            android:textColor="@color/n3"
            android:textSize="@dimen/_14sdp"
            app:drawableTopCompat="@drawable/ic_background_color"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/btnEraser" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.dream.libads.admob.NativeAdStyle3
        android:id="@+id/nativeAdmob"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>